#!/usr/bin/env sh
# Upgrade a git checkout of the Bricks skills pack to the latest GitHub Release.

set -eu

ROOT="${BRICKS_SKILLS_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${BRICKS_SKILLS_STATE_DIR:-$HOME/.bricks-skills}"
VERSION_FILE="$ROOT/VERSION"
RELEASES_API_URL="${BRICKS_SKILLS_RELEASES_API_URL:-https://api.github.com/repos/codeerhq/bricks-skills/releases?per_page=20}"

latest_release_tag() {
	response="$(curl -fsL --max-time 5 "$RELEASES_API_URL" 2>/dev/null || true)"
	printf '%s\n' "$response" | awk 'BEGIN { RS = "\"tag_name\"[[:space:]]*:[[:space:]]*\"" } NR > 1 { split($0, a, "\""); print a[1]; exit }'
}

if [ ! -d "$ROOT/.git" ]; then
	echo "BRICKS_SKILLS_NOT_GIT_INSTALL $ROOT"
	exit 2
fi

OLD_VERSION="unknown"
if [ -f "$VERSION_FILE" ]; then
	OLD_VERSION="$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || echo "unknown")"
fi

cd "$ROOT"

TARGET_TAG="${1:-}"
if [ -z "$TARGET_TAG" ]; then
	TARGET_TAG="$(latest_release_tag | tr -d '[:space:]')"
fi

case "$TARGET_TAG" in
	""|*[!0-9A-Za-z._+-]*)
		echo "BRICKS_SKILLS_NO_RELEASE_FOUND"
		exit 3
		;;
esac

STASH_OUTPUT="$(git stash push -u -m "bricks-skills-upgrade-$(date +%Y%m%d%H%M%S)" 2>&1 || true)"
git fetch --tags origin

if ! git rev-parse -q --verify "refs/tags/$TARGET_TAG^{commit}" >/dev/null; then
	echo "BRICKS_SKILLS_RELEASE_TAG_NOT_FOUND $TARGET_TAG"
	exit 4
fi

git checkout --detach "$TARGET_TAG"
git reset --hard "$TARGET_TAG"

NEW_VERSION="unknown"
if [ -f "$VERSION_FILE" ]; then
	NEW_VERSION="$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || echo "unknown")"
fi

mkdir -p "$STATE_DIR"
echo "$OLD_VERSION" > "$STATE_DIR/just-updated-from"
rm -f "$STATE_DIR/last-update-check"

echo "BRICKS_SKILLS_UPDATED $OLD_VERSION $NEW_VERSION $TARGET_TAG"

case "$STASH_OUTPUT" in
	*"Saved working directory"*) echo "BRICKS_SKILLS_LOCAL_CHANGES_STASHED" ;;
esac
